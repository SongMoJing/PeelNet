import { Button, VerticalBox, HorizontalBox, StandardTableView, Palette } from "std-widgets.slint";
import { Menu } from "../component/menu.slint";

export component AppWindow inherits Window {
    width: 800px;
    height: 600px;

    title: "Rust 控制台";

    background: Palette.background;

    in-out property <int> active-tab: 0;

        VerticalBox {
            padding: 0; spacing: 0;

            // 菜单栏
            Menu {
                menu_data: [
                    {
                        text: "文件",
                        children: [
                            { text: "新建" },
                            { text: "打开" },
                            { text: "保存" },
                            { text: "保存为" },
                            { text: "退出" },
                        ]
                    },
                    {
                        text: "编辑",
                        children: [
                            { text: "撤销" },
                            { text: "重做" },
                            { text: "剪切" },
                        ]
                    }
                ];
            }

        // --- 2. Tab 栏 ---
        Rectangle {
            background: Palette.border; // 使用边框色作为背景分割
            height: 40px;
            HorizontalBox {
                alignment: start;
                padding: 0;
                spacing: 1px;

                // Tab 1: 开始
                Rectangle {
                    width: 100px;
                    // 选中时使用主背景，未选中时使用交替背景
                    background: root.active-tab == 0 ? Palette.background : Palette.alternate-background;
                    Text {
                        text: "开始";
                        color: Palette.foreground;
                    }
                    TouchArea { clicked => { root.active-tab = 0; } }
                }

                // Tab 2: 监控
                Rectangle {
                    width: 100px;
                    background: root.active-tab == 1 ? Palette.background : Palette.alternate-background;
                    Text {
                        text: "监控";
                        color: Palette.foreground;
                    }
                    TouchArea { clicked => { root.active-tab = 1; } }
                }
            }
        }

        // --- 3. 内容区域 ---
        Rectangle {
            VerticalBox {
                alignment: center;
                Text {
                    text: "当前模式：" + (Palette.color-scheme == ColorScheme.dark ? "深色" : "浅色");
                    color: Palette.foreground;
                    font-size: 20px;
                }
                Button {
                    text: "动作按钮";
                    // 标准组件（如 Button）默认就会随系统主题变色
                }
            }
        }
    }
}